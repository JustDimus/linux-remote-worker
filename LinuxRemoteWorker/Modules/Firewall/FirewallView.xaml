<UserControl x:Class="LinuxRemoteWorker.Modules.Firewall.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LinuxRemoteWorker.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
        <conv:ErrorColorConverter x:Key="ErrorColorConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3D5AFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#5A1E1E"/>
            <Setter Property="Foreground" Value="#CF6279"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="100" Visibility="{Binding IsBusyFirewall, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="#AA13131F"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Canvas Width="48" Height="48" HorizontalAlignment="Center">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0" CenterX="24" CenterY="24"/>
                    </Canvas.RenderTransform>
                    <Canvas.Triggers>
                        <EventTrigger RoutedEvent="Canvas.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Canvas.Triggers>
                    <Ellipse Width="48" Height="48" StrokeThickness="4" Stroke="#2A2A4E"/>
                    <Path Stroke="#3D5AFE" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 24,4 A 20,20 0 0 1 44,24"/>
                </Canvas>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#AAA" FontSize="13"
                           HorizontalAlignment="Center" Margin="0 16 0 0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Header -->
                <DockPanel Margin="0 0 0 24">
                    <StackPanel>
                        <TextBlock Text="Firewall (UFW)" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0 0 6 0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#555"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Fill" Value="#6CCF97"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="#888" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Disabled"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Text" Value="Active"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryBtn}" DockPanel.Dock="Right" VerticalAlignment="Top"/>
                </DockPanel>

                <!-- Enable / Disable -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="FIREWALL STATUS" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Foreground="#666" FontSize="12" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Firewall is disabled. All incoming connections are allowed."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Text" Value="Firewall is active. SSH (port 22) is always allowed and cannot be blocked."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="⚡ Enable" Command="{Binding EnableCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0 0 8 0"
                                    Visibility="{Binding IsEnabled, Converter={StaticResource InvertBoolToVisibility}}"/>
                            <Button Content="⏹ Disable" Command="{Binding DisableCommand}"
                                    Style="{StaticResource DangerBtn}"
                                    Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Rules -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="RULES" Style="{StaticResource SectionLabel}"/>

                        <!-- Column headers -->
                        <Grid Margin="8 0 40 4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PORT"   Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="PROTO"  Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="FROM"   Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="ACTION" Foreground="#555" FontSize="10" FontWeight="Bold"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Rules}" Margin="0 0 0 16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0 2" CornerRadius="4" Padding="8 7">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#13131F"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                                        <Setter Property="Background" Value="#1A1A2E"/>
                                                        <Setter Property="BorderBrush" Value="#3D5AFE"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Port}" Foreground="White" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                                <Border Background="#1E2A5E" CornerRadius="3" Padding="4 1" Margin="6 0 0 0"
                                                        Visibility="{Binding IsProtected, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="SSH" Foreground="#3D5AFE" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Proto}"  Foreground="#888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding From}"   Foreground="#6CCF97" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Action}"/>
                                                        <Setter Property="Foreground" Value="#6CCF97"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Action}" Value="deny">
                                                                <Setter Property="Foreground" Value="#CF6279"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="4" Margin="8 0 0 0" Padding="6 0"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteRuleCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Content" Value="✕"/>
                                                        <Setter Property="Foreground" Value="#555"/>
                                                        <Setter Property="FontSize" Value="14"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                                                <Setter Property="Content" Value="🔒"/>
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add rule -->
                        <TextBlock Text="ADD RULE" Style="{StaticResource SectionLabel}" Margin="0 8 0 6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="Port" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0">
                                <TextBlock Text="Proto" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding ProtoOptions}" SelectedItem="{Binding NewProto}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0 0 8 0">
                                <TextBlock Text="From IP (or 'any')" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewFrom, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0 0 8 0">
                                <TextBlock Text="Action" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding NewAction}"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="+ Add" Command="{Binding AddRuleCommand}"
                                    Style="{StaticResource PrimaryBtn}" VerticalAlignment="Bottom"/>
                        </Grid>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0 6 0 0"
                                   Text="{Binding SshPort, StringFormat='SSH port {0} (read from sshd_config) can only be allowed, never denied.'}"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"
                           Foreground="{Binding HasError, Converter={StaticResource ErrorColorConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
