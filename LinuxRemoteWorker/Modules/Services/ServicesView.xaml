<UserControl x:Class="LinuxRemoteWorker.Modules.Services.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LinuxRemoteWorker.Converters"
             xmlns:b="clr-namespace:LinuxRemoteWorker.Behaviors">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:ErrorColorConverter x:Key="ErrorColorConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:ZeroCountToVisibilityConverter x:Key="ZeroCountToVisibility"/>
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibility"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3D5AFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="100" Visibility="{Binding IsBusyServices, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="#AA13131F"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Canvas Width="48" Height="48" HorizontalAlignment="Center">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0" CenterX="24" CenterY="24"/>
                    </Canvas.RenderTransform>
                    <Canvas.Triggers>
                        <EventTrigger RoutedEvent="Canvas.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Canvas.Triggers>
                    <Ellipse Width="48" Height="48" StrokeThickness="4" Stroke="#2A2A4E"/>
                    <Path Stroke="#3D5AFE" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 24,4 A 20,20 0 0 1 44,24"/>
                </Canvas>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#AAA" FontSize="13"
                           HorizontalAlignment="Center" Margin="0 16 0 0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Header -->
                <DockPanel Margin="0 0 0 24">
                    <TextBlock Text=".NET Services" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryBtn}" DockPanel.Dock="Right" VerticalAlignment="Top"/>
                </DockPanel>

                <!-- .NET SDK tooling -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text=".NET SDK" Foreground="White" FontSize="14"/>
                                <TextBlock Text="{Binding DotnetVersion}" Foreground="#666" FontSize="11"
                                           Visibility="{Binding DotnetInstalled, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="Not installed — required to build &amp; publish" Foreground="#CF6279" FontSize="11"
                                           Visibility="{Binding DotnetInstalled, Converter={StaticResource InvertBoolToVisibility}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0" VerticalAlignment="Bottom">
                                <TextBlock Text="Version" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding SdkVersionOptions}" SelectedItem="{Binding SelectedSdkVersion}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Install" Command="{Binding InstallDotnetCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0 0 6 0" VerticalAlignment="Bottom"/>
                            <Button Grid.Column="3" Content="Remove" Command="{Binding UninstallDotnetCommand}"
                                    Background="#5A1E1E" Foreground="#CF6279" BorderThickness="0" Padding="12 8"
                                    FontSize="13" Cursor="Hand" Height="34" VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- Installed SDKs / runtimes -->
                        <Grid Margin="0 12 0 0" Visibility="{Binding InstalledSdks, Converter={StaticResource StringToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="INSTALLED SDKs" Foreground="#555" FontSize="10" FontWeight="Bold" Margin="0 0 0 4"/>
                                <Border Background="#13131F" CornerRadius="4" Padding="8 6">
                                    <TextBlock Text="{Binding InstalledSdks}" Foreground="#6CCF97" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="INSTALLED RUNTIMES" Foreground="#555" FontSize="10" FontWeight="Bold" Margin="0 0 0 4"/>
                                <Border Background="#13131F" CornerRadius="4" Padding="8 6">
                                    <TextBlock Text="{Binding InstalledRuntimes}" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Deploy -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="DEPLOY FROM REPOSITORY" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="Repository" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding AvailableRepos}" SelectedItem="{Binding SelectedRepo}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Project (.csproj)" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding CsprojFiles}" SelectedItem="{Binding SelectedCsproj}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="App name (service = lrw-name)" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding AppName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0">
                                <TextBlock Text="ASPNETCORE_URLS" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding AspNetUrls, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Field}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="🚀 Build &amp; Deploy" Command="{Binding DeployCommand}"
                                    Style="{StaticResource PrimaryBtn}" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Services list -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="SERVICES" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding Services}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#13131F" CornerRadius="6" Padding="12 10" Margin="0 3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0 0 8 0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#CF6279"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Fill" Value="#6CCF97"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding AppName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding StatusText}" Foreground="#666" FontSize="11" Margin="16 2 0 0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="▶ Start" Margin="0 0 4 0" Style="{StaticResource SecondaryBtn}"
                                                        Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="■ Stop" Margin="0 0 4 0" Style="{StaticResource SecondaryBtn}"
                                                        Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="⟳ Restart" Margin="0 0 4 0" Style="{StaticResource SecondaryBtn}"
                                                        Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="⬆ Redeploy" Margin="0 0 4 0"
                                                        Background="#1E3A2E" Foreground="#6CCF97" BorderThickness="0"
                                                        Padding="12 6" FontSize="12" Cursor="Hand"
                                                        Command="{Binding DataContext.RedeployCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="⚙ Manage" Margin="0 0 4 0" Style="{StaticResource SecondaryBtn}"
                                                        Command="{Binding DataContext.SelectServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✕" Style="{StaticResource SecondaryBtn}"
                                                        Command="{Binding DataContext.DeleteServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No services deployed yet." Foreground="#444" FontSize="12" Margin="0 4 0 0"
                                   Visibility="{Binding Services.Count, Converter={StaticResource ZeroCountToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- Selected service detail -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16"
                        Visibility="{Binding SelectedService, Converter={StaticResource NotNullToVisibility}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="{Binding SelectedService.AppName, StringFormat='MANAGE: {0}'}"/>

                        <!-- Unit editor -->
                        <TextBlock Text="systemd unit" Foreground="#888" FontSize="11" Margin="0 4 0 4"/>
                        <TextBox Text="{Binding UnitContent, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#13131F" Foreground="#DDD" BorderBrush="#2A2A3E" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12" Padding="10" CaretBrush="White"
                                 AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="180"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                        <Button Content="💾 Save unit + reload + restart" Command="{Binding SaveUnitCommand}"
                                Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Left" Margin="0 8 0 16"/>

                        <!-- Logs -->
                        <TextBlock Text="journalctl" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                            <Button Content="● Live" Command="{Binding LogsLiveCommand}"
                                    Style="{StaticResource SecondaryBtn}" Margin="0 0 6 0"
                                    Visibility="{Binding IsStreamingLogs, Converter={StaticResource InvertBoolToVisibility}}"/>
                            <Button Content="■ Stop live" Command="{Binding StopLogsCommand}"
                                    Background="#5A1E1E" Foreground="#CF6279" BorderThickness="0" Padding="12 6"
                                    FontSize="12" Cursor="Hand" Margin="0 0 6 0"
                                    Visibility="{Binding IsStreamingLogs, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Last hour" Command="{Binding LogsHourCommand}"
                                    Style="{StaticResource SecondaryBtn}" Margin="0 0 6 0"/>
                            <Button Content="Last day" Command="{Binding LogsDayCommand}"
                                    Style="{StaticResource SecondaryBtn}"/>
                        </StackPanel>
                        <Border Background="#0A0A12" CornerRadius="4" Padding="10">
                            <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto" b:AutoScroll.ToEnd="True">
                                <TextBlock Text="{Binding LogOutput}" Foreground="#9CDCFE"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Output log (deploy) -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16"
                        Visibility="{Binding OutputLog, Converter={StaticResource StringToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="BUILD OUTPUT" Style="{StaticResource SectionLabel}"/>
                        <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto" b:AutoScroll.ToEnd="True">
                            <TextBlock Text="{Binding OutputLog}" Foreground="#6CCF97" FontFamily="Consolas"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"
                           Foreground="{Binding HasError, Converter={StaticResource ErrorColorConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
