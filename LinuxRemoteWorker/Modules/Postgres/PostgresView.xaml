<UserControl x:Class="LinuxRemoteWorker.Modules.Postgres.PostgresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LinuxRemoteWorker.Converters">
    <UserControl.Resources>
        <conv:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:ErrorColorConverter x:Key="ErrorColorConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3D5AFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Busy overlay (only when installed — not during install log) -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsBusyInstalled, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="#AA13131F"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Canvas Width="48" Height="48" HorizontalAlignment="Center">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0" CenterX="24" CenterY="24"/>
                    </Canvas.RenderTransform>
                    <Canvas.Triggers>
                        <EventTrigger RoutedEvent="Canvas.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Canvas.Triggers>
                    <Ellipse Width="48" Height="48" StrokeThickness="4"
                             Stroke="#2A2A4E" Canvas.Left="0" Canvas.Top="0"/>
                    <Path Stroke="#3D5AFE" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 24,4 A 20,20 0 0 1 44,24" Canvas.Left="0" Canvas.Top="0"/>
                </Canvas>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#AAA" FontSize="13"
                           HorizontalAlignment="Center" Margin="0 16 0 0"/>
            </StackPanel>
        </Grid>

        <!-- NOT INSTALLED -->
        <Grid Visibility="{Binding IsInstalled, Converter={StaticResource InvertBoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="🐘" FontSize="56" HorizontalAlignment="Center" Margin="0 0 0 16"/>
                <TextBlock Text="PostgreSQL is not installed" Foreground="White" FontSize="20"
                           FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0 0 0 8"/>
                <TextBlock Text="Install PostgreSQL on this server to manage databases, users and connection settings."
                           Foreground="#666" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0 0 0 32"/>

                <Button Content="Install PostgreSQL" Command="{Binding InstallCommand}"
                        Style="{StaticResource PrimaryBtn}" Padding="0 16" FontSize="15"
                        IsEnabled="{Binding IsInstalling, Converter={StaticResource InvertBoolConverter}}"/>

                <Border Margin="0 16 0 0" Background="#1E1E2E" CornerRadius="6" Padding="12"
                        Visibility="{Binding InstallLog, Converter={StaticResource StringToVisibility}}">
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding InstallLog}" Foreground="#6CCF97" FontFamily="Consolas"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>

        <!-- INSTALLED -->
        <ScrollViewer Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Header -->
                <DockPanel Margin="0 0 0 24">
                    <StackPanel>
                        <TextBlock Text="PostgreSQL" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                            <TextBlock Text="{Binding Version}" Foreground="#666" FontSize="12" Margin="0 0 16 0"/>
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0 0 6 0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#CF6279"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ServiceStatus}" Value="active">
                                                <Setter Property="Fill" Value="#6CCF97"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ServiceStatus}" Foreground="#888" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="⟳ Restart" Command="{Binding RestartServiceCommand}"
                                Style="{StaticResource SecondaryBtn}" Margin="0 0 8 0" VerticalAlignment="Top"/>
                        <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryBtn}" VerticalAlignment="Top"/>
                    </StackPanel>
                </DockPanel>

                <!-- Network settings -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="NETWORK SETTINGS" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0 0 0 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 12 0">
                                <TextBlock Text="Listen Addresses" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                                <TextBox Text="{Binding ListenAddresses, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Port" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Save &amp; Reload" Command="{Binding SaveListenAddressCommand}"
                                Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- pg_hba rules -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="ACCESS RULES (pg_hba.conf)" Style="{StaticResource SectionLabel}"/>

                        <!-- Column headers -->
                        <Grid Margin="8 0 32 4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TYPE"     Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="DATABASE" Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="USER"     Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="ADDRESS"  Foreground="#555" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="METHOD"   Foreground="#555" FontSize="10" FontWeight="Bold"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding HbaRules}" Margin="0 0 0 12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#13131F" CornerRadius="4" Padding="8 6" Margin="0 2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Type}"     Foreground="#7B8CDE" FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Database}" Foreground="#AAA"    FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="{Binding User}"     Foreground="#AAA"    FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Address}"  Foreground="#6CCF97" FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Method}"   Foreground="#CF9A6C" FontFamily="Consolas" FontSize="12"/>
                                            <Button Grid.Column="5" Content="✕" Margin="8 0 0 0"
                                                    Command="{Binding DataContext.RemoveHbaRuleCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#555" FontSize="14" Cursor="Hand" Padding="4 0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="ADD RULE" Style="{StaticResource SectionLabel}" Margin="0 8 0 6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="IP / CIDR" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewAllowIp, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0">
                                <TextBlock Text="User" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewAllowUser, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0 0 8 0">
                                <TextBlock Text="Database" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewAllowDb, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0 0 8 0">
                                <TextBlock Text="Method" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <ComboBox ItemsSource="{Binding AuthMethods}"
                                          SelectedItem="{Binding NewAllowMethod}"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="+ Add" Command="{Binding AddHbaRuleCommand}"
                                    Style="{StaticResource PrimaryBtn}" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Users -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="USERS" Style="{StaticResource SectionLabel}"/>

                        <!-- User list -->
                        <ItemsControl ItemsSource="{Binding Users}" Margin="0 0 0 12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#13131F" CornerRadius="6" Padding="10 8" Margin="0 2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                                <Border Background="#2A2A4E" CornerRadius="3" Padding="5 2" Margin="8 0 0 0"
                                                        Visibility="{Binding IsSuperuser, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="superuser" Foreground="#7B8CDE" FontSize="10"/>
                                                </Border>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Change Password"
                                                    Command="{Binding DataContext.ChangePasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#2A2A3E" Foreground="#AAA" BorderThickness="0"
                                                    Padding="10 6" FontSize="12" Cursor="Hand" Margin="0 0 6 0"/>
                                            <Button Grid.Column="2" Content="Use in ConnStr"
                                                    Command="{Binding DataContext.UseUserInConnStrCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#2A2A3E" Foreground="#AAA" BorderThickness="0"
                                                    Padding="10 6" FontSize="12" Cursor="Hand" Margin="0 0 6 0"/>
                                            <Button Grid.Column="3" Content="✕"
                                                    Command="{Binding DataContext.DropUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Foreground="#555" BorderThickness="0"
                                                    Padding="6 0" FontSize="14" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Create user -->
                        <TextBlock Text="CREATE USER" Style="{StaticResource SectionLabel}" Margin="0 8 0 6"/>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="Username" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0">
                                <TextBlock Text="Password" Foreground="#555" FontSize="10" Margin="0 0 0 3"/>
                                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0 0 8 0" VerticalAlignment="Bottom">
                                <CheckBox Content="Superuser" IsChecked="{Binding NewUserSuperuser}"
                                          Foreground="#AAA" Margin="0 0 0 8"/>
                            </StackPanel>
                            <Button Grid.Column="3" Content="+ Create" Command="{Binding CreateUserCommand}"
                                    Style="{StaticResource PrimaryBtn}" VerticalAlignment="Bottom"/>
                        </Grid>
                        <TextBlock Text="For 'Change Password' — type the new password in the Password field above, then click the button next to the user."
                                   Foreground="#444" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Connection string -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="CONNECTION STRING" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="0 0 0 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                <TextBlock Text="Database" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                                <TextBox Text="{Binding ConnStringDb, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0 0 8 0">
                                <TextBlock Text="User" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                                <TextBox Text="{Binding ConnStringUser, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Password" Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
                                <TextBox Text="{Binding ConnStringPassword, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Generate" Command="{Binding GenerateConnectionStringCommand}"
                                Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Left" Margin="0 0 0 12"/>

                        <Grid Visibility="{Binding ConnectionString, Converter={StaticResource StringToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#13131F" CornerRadius="4" Padding="10 8">
                                <TextBlock Text="{Binding ConnectionString}" Foreground="#6CCF97"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                            <Button Grid.Column="1" Content="📋 Copy" Command="{Binding CopyConnectionStringCommand}"
                                    Style="{StaticResource SecondaryBtn}" Margin="8 0 0 0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0 0 0 16"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"
                           Foreground="{Binding HasError, Converter={StaticResource ErrorColorConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
