<UserControl x:Class="LinuxRemoteWorker.Views.InfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#1E1E2E" CornerRadius="8" Padding="16">
        <StackPanel>
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="#888" FontSize="11" Margin="0 0 0 4"/>
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="White" FontSize="15" FontWeight="Medium" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
