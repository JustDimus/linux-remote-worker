<Window x:Class="LinuxRemoteWorker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LinuxRemoteWorker.ViewModels"
        xmlns:views="clr-namespace:LinuxRemoteWorker.Views"
        xmlns:sysinfo="clr-namespace:LinuxRemoteWorker.Modules.SystemInfo"
        xmlns:pg="clr-namespace:LinuxRemoteWorker.Modules.Postgres"
        xmlns:fw="clr-namespace:LinuxRemoteWorker.Modules.Firewall"
        xmlns:repo="clr-namespace:LinuxRemoteWorker.Modules.Repositories"
        xmlns:svc="clr-namespace:LinuxRemoteWorker.Modules.Services"
        xmlns:conv="clr-namespace:LinuxRemoteWorker.Converters"
        Title="Linux Remote Worker" Height="700" Width="1100"
        Background="#13131F" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <conv:ErrorColorConverter x:Key="ErrorColorConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- DataTemplate: ViewModel → View -->
        <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
            <views:ConnectView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type sysinfo:SystemInfoViewModel}">
            <sysinfo:SystemInfoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type pg:PostgresViewModel}">
            <pg:PostgresView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type fw:FirewallViewModel}">
            <fw:FirewallView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type repo:RepositoriesViewModel}">
            <repo:RepositoriesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type svc:ServicesViewModel}">
            <svc:ServicesView/>
        </DataTemplate>

        <!-- Sidebar nav button -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8 8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0D0D1A">
            <DockPanel>
                <!-- App title -->
                <Border DockPanel.Dock="Top" Padding="16 20" BorderBrush="#2A2A3E" BorderThickness="0 0 0 1">
                    <StackPanel>
                        <TextBlock Text="Linux Remote Worker" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ConnectVM.Host, StringFormat='→ {0}'}"
                                   Foreground="#555" FontSize="11" Margin="0 4 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Module nav -->
                <StackPanel DockPanel.Dock="Top" Margin="8 8">

                    <!-- Connection -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding ConnectVM}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" Margin="0 0 8 0"/>
                            <TextBlock Text="Connection"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="MODULES" Foreground="#444" FontSize="10" Margin="8 12 0 4" FontWeight="Bold"/>

                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding SystemInfoVM}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥" Margin="0 0 8 0"/>
                            <TextBlock Text="System Info"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding PostgresVM}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐘" Margin="0 0 8 0"/>
                            <TextBlock Text="PostgreSQL"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding RepositoriesVM}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" Margin="0 0 8 0"/>
                            <TextBlock Text="Repositories"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding ServicesVM}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0 0 8 0"/>
                            <TextBlock Text=".NET Services"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding FirewallVM}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛡" Margin="0 0 8 0"/>
                            <TextBlock Text="Firewall"/>
                        </StackPanel>
                    </Button>
                    <Button IsEnabled="False" Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0 0 8 0"/>
                            <TextBlock Text="Logs"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Connection indicator at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="16 12" BorderBrush="#2A2A3E" BorderThickness="0 1 0 0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0 0 8 0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#555"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#6CCF97"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Not connected"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="Connected"/>
                                            <Setter Property="Foreground" Value="#6CCF97"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Border Grid.Column="1" Background="#13131F">
            <ContentControl Content="{Binding ActiveModule}"/>
        </Border>
    </Grid>
</Window>
